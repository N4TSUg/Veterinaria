@model Veterinaria.ViewModels.Usuario.UsuarioCreateVM

@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="max-w-xl mx-auto bg-surface-container-lowest border border-outline-variant rounded-xl p-lg shadow-sm">
    <div class="flex items-center gap-2 mb-6 border-b border-outline-variant pb-4">
        <span class="material-symbols-outlined text-primary text-3xl">person_add</span>
        <h2 class="text-headline-md font-headline-md text-on-surface">Crear Nuevo Usuario</h2>
    </div>

    <form asp-action="Create" class="space-y-6">
        @Html.AntiForgeryToken()
        
        <div>
            <label asp-for="NameUser" class="block text-label-md font-label-md text-on-surface mb-2">Nombre Completo</label>
            <input asp-for="NameUser" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" placeholder="Ej. Juan Pérez" />
            <span asp-validation-for="NameUser" class="text-error text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="EmailUser" class="block text-label-md font-label-md text-on-surface mb-2">Correo Electrónico (Login)</label>
            <input asp-for="EmailUser" type="email" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" placeholder="juan@veterinaria.com" />
            <span asp-validation-for="EmailUser" class="text-error text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="PasswordUser" class="block text-label-md font-label-md text-on-surface mb-2">Contraseña</label>
            <input asp-for="PasswordUser" type="password" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" />
            <span asp-validation-for="PasswordUser" class="text-error text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="IdRol" class="block text-label-md font-label-md text-on-surface mb-2">Rol del Sistema</label>
            <select asp-for="IdRol" asp-items="ViewBag.Roles" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow">
                <option value="">Seleccione un rol...</option>
            </select>
            <span asp-validation-for="IdRol" class="text-error text-xs mt-1 block"></span>
        </div>

        <div class="flex justify-end gap-4 pt-4 border-t border-outline-variant">
            <a asp-action="Index" class="px-6 py-2 border border-outline-variant text-on-surface-variant rounded-lg hover:bg-surface-container transition-colors">Cancelar</a>
            <button type="submit" class="bg-primary text-on-primary px-6 py-2 rounded-lg hover:bg-on-primary-fixed-variant transition-colors shadow">Crear Usuario</button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
