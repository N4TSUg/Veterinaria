@model Veterinaria.ViewModels.Mascota.MascotaEditVM

@{
    ViewData["Title"] = "Editar Mascota";
}

<div class="max-w-2xl mx-auto bg-surface-container-lowest border border-outline-variant rounded-xl p-lg shadow-sm">
    <div class="flex items-center gap-2 mb-6 border-b border-outline-variant pb-4">
        <span class="material-symbols-outlined text-primary text-3xl">edit</span>
        <h2 class="text-headline-md font-headline-md text-on-surface">Editar Mascota</h2>
    </div>

    <form asp-action="Edit" enctype="multipart/form-data" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdMascota" />
        <input type="hidden" asp-for="FotoUrl" />

        <div>
            <label asp-for="IdCliente" class="block text-label-md font-label-md text-on-surface mb-2">Propietario (Cliente)</label>
            <select asp-for="IdCliente" asp-items="Model.Clientes" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow">
            </select>
            <span asp-validation-for="IdCliente" class="text-error text-xs mt-1 block"></span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label asp-for="Nombre" class="block text-label-md font-label-md text-on-surface mb-2">Nombre de la Mascota</label>
                <input asp-for="Nombre" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" />
                <span asp-validation-for="Nombre" class="text-error text-xs mt-1 block"></span>
            </div>
            
            <div>
                <label asp-for="Especie" class="block text-label-md font-label-md text-on-surface mb-2">Especie</label>
                <input asp-for="Especie" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" />
                <span asp-validation-for="Especie" class="text-error text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Raza" class="block text-label-md font-label-md text-on-surface mb-2">Raza</label>
                <input asp-for="Raza" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" />
                <span asp-validation-for="Raza" class="text-error text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Sexo" class="block text-label-md font-label-md text-on-surface mb-2">Sexo</label>
                <select asp-for="Sexo" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow">
                    <option value="Macho">Macho</option>
                    <option value="Hembra">Hembra</option>
                </select>
                <span asp-validation-for="Sexo" class="text-error text-xs mt-1 block"></span>
            </div>
            
            <div>
                <label asp-for="Edad" class="block text-label-md font-label-md text-on-surface mb-2">Edad (años)</label>
                <input asp-for="Edad" type="number" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" />
                <span asp-validation-for="Edad" class="text-error text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Peso" class="block text-label-md font-label-md text-on-surface mb-2">Peso (kg)</label>
                <input asp-for="Peso" type="number" step="0.01" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" />
                <span asp-validation-for="Peso" class="text-error text-xs mt-1 block"></span>
            </div>
        </div>

        <div class="flex justify-end gap-4 pt-4 border-t border-outline-variant">
            <a asp-action="Index" class="px-6 py-2 border border-outline-variant text-on-surface-variant rounded-lg hover:bg-surface-container transition-colors">Cancelar</a>
            <button type="submit" class="bg-primary text-on-primary px-6 py-2 rounded-lg hover:bg-on-primary-fixed-variant transition-colors shadow">Actualizar Mascota</button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
