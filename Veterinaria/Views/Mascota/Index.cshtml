@model IEnumerable<Veterinaria.Models.Mascota>

@{
    ViewData["Title"] = "Gestión de Mascotas";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h2 class="text-headline-lg font-headline-lg text-on-background">Gestión de Mascotas</h2>
        <p class="text-body-md font-body-md text-on-surface-variant mt-1">Directorio completo de pacientes registrados en el sistema.</p>
    </div>
    <a asp-action="Create" class="bg-primary text-on-primary font-label-md text-label-md px-6 py-3 rounded-lg hover:bg-primary-container transition-colors duration-200 flex items-center gap-2 shadow-sm cursor-pointer">
        <span class="material-symbols-outlined text-sm">add</span>
        Registrar Nueva Mascota
    </a>
</div>

<!-- Mascotas List Table -->
<div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container-low border-b border-outline-variant text-label-md font-label-md text-on-surface-variant uppercase tracking-wider">
                    <th class="px-6 py-4 font-semibold">Nombre</th>
                    <th class="px-6 py-4 font-semibold">Especie / Raza</th>
                    <th class="px-6 py-4 font-semibold">Sexo / Edad</th>
                    <th class="px-6 py-4 font-semibold">Propietario</th>
                    <th class="px-6 py-4 font-semibold text-right">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant text-body-md font-body-md">
                @foreach(var item in Model)
                {
                    <tr class="hover:bg-surface-container-lowest transition-colors cursor-pointer" onclick="window.location.href='@Url.Action("Details", "Mascota", new { id = item.IdMascota })'">
                        <td class="px-6 py-4 font-medium text-on-surface">@item.Nombre</td>
                        <td class="px-6 py-4 text-on-surface">@item.Especie - @item.Raza</td>
                        <td class="px-6 py-4 text-on-surface-variant">@item.Sexo, @item.EdadCalculada</td>
                        <td class="px-6 py-4 text-on-surface-variant">@item.Cliente?.Nombre @item.Cliente?.Apellido</td>
                        <td class="px-6 py-4 text-right space-x-2" onclick="event.stopPropagation();">
                            <a asp-action="Edit" asp-route-id="@item.IdMascota" class="text-on-surface-variant hover:text-on-surface p-1 rounded transition-colors inline-block" title="Editar">
                                <span class="material-symbols-outlined text-sm">edit</span>
                            </a>
                            <button type="button" onclick="openDeleteModal('@Url.Action("Delete", "Mascota", new { id = item.IdMascota })', '¿Eliminar mascota @item.Nombre?');" class="text-error hover:text-on-error-container p-1 rounded transition-colors" title="Eliminar">
                                <span class="material-symbols-outlined text-sm">delete</span>
                            </button>
                        </td>
                    </tr>
                }
                
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center text-on-surface-variant">No hay mascotas registradas.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
