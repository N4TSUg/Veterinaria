<!DOCTYPE html>
<html lang="es" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Veterinaria Bryan</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🐾</text></svg>">
    
    <!-- Tailwind CSS (CDN para MVP) -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    
    <!-- Google Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <!-- Tema de colores inyectado (del diseño exportado) -->
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#003c90",
                        "on-primary": "#ffffff",
                        "primary-container": "#0f52ba",
                        "on-primary-container": "#bcceff",
                        "secondary": "#006c44",
                        "on-secondary": "#ffffff",
                        "secondary-container": "#97f3be",
                        "on-secondary-container": "#037148",
                        "background": "#f8f9ff",
                        "on-background": "#0b1c30",
                        "surface": "#f8f9ff",
                        "on-surface": "#0b1c30",
                        "surface-variant": "#d3e4fe",
                        "on-surface-variant": "#434653",
                        "outline": "#737784",
                        "outline-variant": "#c3c6d5",
                        "error": "#ba1a1a",
                        "on-error": "#ffffff",
                        "error-container": "#ffdad6",
                        "on-error-container": "#93000a",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-low": "#eff4ff",
                        "surface-container": "#e5eeff",
                        "surface-container-high": "#dce9ff"
                    },
                    fontFamily: {
                        "headline-lg": ["Inter", "sans-serif"],
                        "headline-md": ["Inter", "sans-serif"],
                        "body-lg": ["Inter", "sans-serif"],
                        "body-md": ["Inter", "sans-serif"],
                        "label-md": ["Inter", "sans-serif"],
                        "display-lg": ["Inter", "sans-serif"]
                    },
                    spacing: {
                        "xs": "4px",
                        "sm": "8px",
                        "md": "16px",
                        "lg": "24px",
                        "xl": "40px"
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-background text-on-background font-body-md min-h-screen">

    @if (User.Identity!.IsAuthenticated)
    {
        <!-- TopNavBar -->
        <header class="fixed top-0 right-0 w-full md:w-[calc(100%-260px)] h-16 bg-surface border-b border-outline-variant flex justify-between items-center px-4 md:px-lg z-20">
            <div class="flex items-center gap-2">
                <button id="mobile-menu-btn" class="md:hidden text-primary hover:bg-surface-container p-2 rounded-lg transition-colors flex items-center justify-center">
                    <span class="material-symbols-outlined">menu</span>
                </button>
                <h1 class="text-headline-md font-headline-md font-extrabold text-primary hidden sm:block">Veterinaria Bryan</h1>
                <h1 class="text-headline-md font-headline-md font-extrabold text-primary sm:hidden">Vet. Bryan</h1>
            </div>
            <div class="flex items-center gap-md">
                <div class="relative hidden md:block" id="global-search-container">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant" style="font-variation-settings: 'FILL' 0;">search</span>
                    <input id="global-search-input" class="w-64 pl-10 pr-4 py-2 bg-surface-container-low border-none rounded-full text-body-md font-body-md focus:ring-2 focus:ring-primary focus:outline-none transition-shadow" placeholder="Buscar pacientes, dueños..." type="text" autocomplete="off" />
                    
                    <!-- Search Results Dropdown -->
                    <div id="global-search-results" class="absolute top-full left-0 mt-2 w-80 bg-surface-container-lowest border border-outline-variant rounded-xl shadow-lg overflow-hidden hidden z-50">
                        <ul id="global-search-list" class="divide-y divide-outline-variant">
                            <!-- Results will be injected here -->
                        </ul>
                    </div>
                </div>
                
                <div class="flex items-center gap-2 ml-sm">
                    <span class="text-body-md font-bold text-on-surface">@User.Identity.Name</span>
                    <div class="w-8 h-8 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center font-bold">
                        @User.Identity.Name?.Substring(0,1).ToUpper()
                    </div>
                </div>
            </div>
        </header>

        <!-- SideNavBar Backdrop -->
        <div id="mobile-sidebar-backdrop" class="fixed inset-0 bg-on-surface/40 backdrop-blur-sm z-20 hidden md:hidden transition-opacity"></div>

        <!-- SideNavBar -->
        <nav id="sidebar" class="fixed left-0 top-0 h-full w-[260px] bg-surface-container-lowest border-r border-outline-variant flex flex-col py-lg z-30 transform -translate-x-full md:translate-x-0 transition-transform duration-300">
            <div class="px-md mb-lg flex justify-between items-start">
                <div class="flex items-center gap-sm mb-xs">
                    <div class="w-10 h-10 rounded-lg overflow-hidden bg-primary-container text-on-primary-container flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">pets</span>
                    </div>
                    <div>
                        <h2 class="text-headline-md font-headline-md font-bold text-primary">Vet. Bryan</h2>
                        <p class="text-label-md font-label-md text-on-surface-variant">
                            @if (User.HasClaim(c => c.Type == System.Security.Claims.ClaimTypes.Role))
                            {
                                @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                            }
                        </p>
                    </div>
                </div>
                <button id="mobile-close-btn" class="md:hidden text-on-surface-variant hover:bg-surface-container p-1 rounded-lg">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="px-md mb-md">
                <a asp-controller="Mascota" asp-action="Create" class="w-full bg-primary text-on-primary py-2 px-4 rounded-lg flex items-center justify-center gap-sm font-body-md hover:opacity-90 transition-opacity shadow-sm cursor-pointer active:scale-95 transition-transform">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">add</span>
                    Nueva Mascota
                </a>
            </div>

            <ul class="flex-1 flex flex-col gap-xs mt-sm">
                <!-- Dashboard -->
                <li>
                    <a asp-controller="Home" asp-action="Index" class="flex items-center gap-md px-md py-sm @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "text-primary border-l-4 border-primary font-bold bg-surface-container-low" : "text-on-surface-variant hover:text-on-surface hover:bg-surface-container") cursor-pointer transition-all">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">dashboard</span>
                        <span class="text-body-md font-body-md">Inicio</span>
                    </a>
                </li>
                <!-- Calendario -->
                <li>
                    <a asp-controller="Calendario" asp-action="Index" class="flex items-center gap-md px-md py-sm @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Calendario" ? "text-primary border-l-4 border-primary font-bold bg-surface-container-low" : "text-on-surface-variant hover:text-on-surface hover:bg-surface-container") cursor-pointer transition-all">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">calendar_month</span>
                        <span class="text-body-md font-body-md">Calendario</span>
                    </a>
                </li>
                <!-- Clientes -->
                <li>
                    <a asp-controller="Cliente" asp-action="Index" class="flex items-center gap-md px-md py-sm @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Cliente" ? "text-primary border-l-4 border-primary font-bold bg-surface-container-low" : "text-on-surface-variant hover:text-on-surface hover:bg-surface-container") cursor-pointer transition-all">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">group</span>
                        <span class="text-body-md font-body-md">Clientes</span>
                    </a>
                </li>
                <!-- Mascotas -->
                <li>
                    <a asp-controller="Mascota" asp-action="Index" class="flex items-center gap-md px-md py-sm @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Mascota" ? "text-primary border-l-4 border-primary font-bold bg-surface-container-low" : "text-on-surface-variant hover:text-on-surface hover:bg-surface-container") cursor-pointer transition-all">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">pets</span>
                        <span class="text-body-md font-body-md">Mascotas</span>
                    </a>
                </li>
                <!-- Vacunas -->
                <li>
                    <a asp-controller="Vacuna" asp-action="Monitoreo" class="flex items-center gap-md px-md py-sm @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Vacuna" ? "text-primary border-l-4 border-primary font-bold bg-surface-container-low" : "text-on-surface-variant hover:text-on-surface hover:bg-surface-container") cursor-pointer transition-all">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">vaccines</span>
                        <span class="text-body-md font-body-md">Vacunas</span>
                    </a>
                </li>
                @if (User.HasClaim(System.Security.Claims.ClaimTypes.Role, "Administrador"))
                {
                    <!-- Personal -->
                    <li>
                        <a asp-controller="Usuario" asp-action="Index" class="flex items-center gap-md px-md py-sm @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Usuario" ? "text-primary border-l-4 border-primary font-bold bg-surface-container-low" : "text-on-surface-variant hover:text-on-surface hover:bg-surface-container") cursor-pointer transition-all">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">badge</span>
                            <span class="text-body-md font-body-md">Personal</span>
                        </a>
                    </li>
                }
            </ul>

            <div class="mt-auto px-xs">
                <div class="h-px w-full bg-outline-variant mb-xs"></div>
                <form asp-controller="Access" asp-action="Logout" method="post">
                    <button type="submit" class="w-full flex items-center gap-md px-md py-sm text-error hover:bg-error-container transition-colors duration-200 cursor-pointer active:scale-95 transition-transform rounded-lg">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">logout</span>
                        <span class="text-body-md font-body-md">Cerrar Sesión</span>
                    </button>
                </form>
            </div>
        </nav>

        <!-- Main Content Canvas -->
        <main class="ml-0 md:ml-[260px] pt-20 md:pt-24 p-4 md:p-lg min-h-screen bg-background">
            <div class="max-w-[1440px] mx-auto">
                @if (TempData["Success"] != null)
                {
                    <div class="bg-secondary-container text-on-secondary-container p-4 rounded-lg mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined">check_circle</span>
                        @TempData["Success"]
                    </div>
                }
                @RenderBody()
            </div>
        </main>
    }
    else
    {
        <!-- Content without Navigation (for Login) -->
        <main class="min-h-screen bg-surface-container-low flex items-center justify-center p-md">
            @RenderBody()
        </main>
    }

    <!-- Delete Confirmation Modal (Generic) -->
    <div id="deleteModal" class="fixed inset-0 z-50 hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <!-- Background backdrop -->
        <div class="fixed inset-0 bg-on-surface/40 backdrop-blur-sm transition-opacity" id="deleteModalBackdrop"></div>

        <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
            <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
                <div class="relative transform overflow-hidden rounded-xl bg-surface-container-lowest text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg border border-outline-variant">
                    <div class="bg-surface-container-lowest px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
                        <div class="sm:flex sm:items-start">
                            <div class="mx-auto flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-error-container sm:mx-0 sm:h-10 sm:w-10">
                                <span class="material-symbols-outlined text-error">warning</span>
                            </div>
                            <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left">
                                <h3 class="text-headline-sm font-headline-sm text-on-surface" id="modal-title">Eliminar Registro</h3>
                                <div class="mt-2">
                                    <p class="text-body-md text-on-surface-variant" id="deleteModalMessage">
                                        ¿Estás seguro de que deseas eliminar este registro? Esta acción no se puede deshacer.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="bg-surface-container-low px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6 border-t border-outline-variant">
                        <form id="deleteModalForm" method="post" class="w-full sm:w-auto">
                            <button type="submit" class="inline-flex w-full justify-center rounded-lg bg-error px-6 py-2 text-label-md font-label-md text-on-error shadow-sm hover:bg-error/90 sm:ml-3 sm:w-auto">Eliminar</button>
                        </form>
                        <button type="button" onclick="closeDeleteModal()" class="mt-3 inline-flex w-full justify-center rounded-lg bg-surface-container-lowest px-6 py-2 text-label-md font-label-md text-on-surface-variant shadow-sm ring-1 ring-inset ring-outline-variant hover:bg-surface-container sm:mt-0 sm:w-auto">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        // Modal logic
        function openDeleteModal(url, message) {
            document.getElementById('deleteModalForm').action = url;
            if(message) {
                document.getElementById('deleteModalMessage').innerText = message;
            }
            document.getElementById('deleteModal').classList.remove('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
        }

        // Mobile Sidebar Logic
        $(document).ready(function () {
            const sidebar = $('#sidebar');
            const backdrop = $('#mobile-sidebar-backdrop');
            
            $('#mobile-menu-btn').click(function() {
                sidebar.removeClass('-translate-x-full');
                backdrop.removeClass('hidden');
            });
            
            $('#mobile-close-btn, #mobile-sidebar-backdrop').click(function() {
                sidebar.addClass('-translate-x-full');
                backdrop.addClass('hidden');
            });

            let searchTimeout;
            const searchInput = $('#global-search-input');
            const searchResults = $('#global-search-results');
            const searchList = $('#global-search-list');

            searchInput.on('input', function () {
                clearTimeout(searchTimeout);
                const query = $(this).val();

                if (query.length < 2) {
                    searchResults.addClass('hidden');
                    return;
                }

                searchTimeout = setTimeout(function () {
                    $.ajax({
                        url: '/Search/Buscar',
                        data: { q: query },
                        method: 'GET',
                        success: function (data) {
                            searchList.empty();
                            if (data && data.length > 0) {
                                data.forEach(item => {
                                    searchList.append(`
                                        <li>
                                            <a href="${item.url}" class="flex items-center gap-3 p-3 hover:bg-surface-container-low transition-colors cursor-pointer">
                                                <div class="w-8 h-8 rounded-full bg-primary-container/30 text-primary flex items-center justify-center shrink-0">
                                                    <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">${item.icon}</span>
                                                </div>
                                                <div class="overflow-hidden">
                                                    <h4 class="text-body-md font-bold text-on-surface truncate">${item.title}</h4>
                                                    <p class="text-label-sm text-on-surface-variant truncate">${item.subtitle}</p>
                                                </div>
                                            </a>
                                        </li>
                                    `);
                                });
                            } else {
                                searchList.append(`
                                    <li class="p-4 text-center text-on-surface-variant">
                                        <span class="text-label-md">No se encontraron resultados</span>
                                    </li>
                                `);
                            }
                            searchResults.removeClass('hidden');
                        }
                    });
                }, 300); // 300ms debounce
            });

            // Cierra el dropdown al hacer clic fuera
            $(document).on('click', function (e) {
                if (!$(e.target).closest('#global-search-container').length) {
                    searchResults.addClass('hidden');
                }
            });
            
            // Re-abre el dropdown si hay texto al hacer clic en el input
            searchInput.on('focus', function() {
                if ($(this).val().length >= 2 && searchList.children().length > 0) {
                    searchResults.removeClass('hidden');
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
