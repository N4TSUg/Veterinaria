@model IEnumerable<Veterinaria.Models.VacunaAplicada>

@{
    ViewData["Title"] = "Gestión de Vacunas (Monitoreo)";
}

<div class="flex flex-col gap-lg">
    <!-- Header Section -->
    <div class="flex items-end justify-between">
        <div>
            <h2 class="text-headline-lg font-headline-lg text-on-surface mb-xs">Gestión de Vacunas</h2>
            <p class="text-body-md font-body-md text-on-surface-variant">Monitorea y administra el calendario de vacunación de los pacientes.</p>
        </div>
        <a asp-action="Index" class="bg-surface-container-lowest text-primary border border-outline-variant font-label-md text-label-md px-md py-sm rounded-lg flex items-center gap-sm hover:bg-surface-container-low transition-all shadow-sm">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">list</span>
            Catálogo
        </a>
    </div>

    <!-- Data Presentation: Bento Grid Rows -->
    <div class="flex flex-col gap-sm">
        <!-- Header Row -->
        <div class="grid grid-cols-12 gap-md px-md py-sm bg-surface-container rounded-lg border border-outline-variant text-label-md font-label-md text-on-surface-variant uppercase tracking-wider hidden md:grid">
            <div class="col-span-12 md:col-span-3">Mascota</div>
            <div class="col-span-12 md:col-span-3">Vacuna</div>
            <div class="col-span-12 md:col-span-2">Fecha Aplicación</div>
            <div class="col-span-12 md:col-span-2">Próxima Dosis</div>
            <div class="col-span-12 md:col-span-2 text-right">Estado</div>
        </div>

        @foreach(var item in Model)
        {
            var isVencida = item.FechaProximaDosis.HasValue && item.FechaProximaDosis.Value < DateTime.UtcNow.AddHours(-5);
            var isPendiente = item.FechaProximaDosis.HasValue && !isVencida && item.FechaProximaDosis.Value <= DateTime.UtcNow.AddHours(-5).AddDays(7);
            var esDosisUnica = !item.FechaProximaDosis.HasValue;
            
            var rowClass = isVencida 
                ? "bg-error-container/10 border-error-container" 
                : "bg-surface-container-lowest border-outline-variant";

            <a asp-controller="Mascota" asp-action="Details" asp-route-id="@item.IdMascota" class="grid grid-cols-1 md:grid-cols-12 gap-md px-md py-md rounded-lg border @rowClass items-center hover:shadow-md transition-shadow group relative overflow-hidden cursor-pointer block">
                
                @if (isVencida)
                {
                    <!-- Subtle red left border accent -->
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-error"></div>
                }

                <div class="md:col-span-3 flex items-center gap-md pl-xs">
                    <div class="w-10 h-10 rounded-full overflow-hidden border border-outline-variant flex-shrink-0 bg-surface-variant text-on-surface-variant flex items-center justify-center">
                        <span class="material-symbols-outlined">pets</span>
                    </div>
                    <div>
                        <p class="text-body-md font-body-md font-semibold text-on-surface group-hover:text-primary transition-colors">@item.Mascota?.Nombre</p>
                        <p class="text-label-md font-label-md text-on-surface-variant truncate">@item.Mascota?.Cliente?.Nombre @item.Mascota?.Cliente?.Apellido</p>
                    </div>
                </div>

                <div class="md:col-span-3">
                    <p class="text-body-md font-body-md text-on-surface">@item.Vacuna?.Nombre</p>
                    <p class="text-label-md font-label-md text-on-surface-variant">@item.Vacuna?.Tipo</p>
                </div>

                <div class="md:col-span-2 text-body-md font-body-md text-on-surface">
                    <span class="md:hidden font-bold text-xs uppercase block text-on-surface-variant">Aplicada:</span>
                    @item.FechaAplicacion.ToString("dd MMM yyyy")
                </div>

                <div class="md:col-span-2 text-body-md font-body-md @(isVencida ? "text-error font-semibold" : "text-on-surface-variant")">
                    <span class="md:hidden font-bold text-xs uppercase block text-on-surface-variant">Próxima Dosis:</span>
                    @(esDosisUnica ? "Única Dosis / No requiere" : item.FechaProximaDosis?.ToString("dd MMM yyyy"))
                </div>

                <div class="md:col-span-2 flex justify-start md:justify-end mt-2 md:mt-0">
                    @if (esDosisUnica)
                    {
                        <span class="inline-flex items-center gap-xs px-3 py-1 rounded-full bg-surface-variant text-on-surface-variant text-label-md font-label-md">
                            <span class="material-symbols-outlined text-[16px]">done_all</span>
                            Completada
                        </span>
                    }
                    else if (isVencida)
                    {
                        <span class="inline-flex items-center gap-xs px-3 py-1 rounded-full bg-error-container text-on-error-container text-label-md font-label-md">
                            <span class="material-symbols-outlined text-[16px]">warning</span>
                            Vencida
                        </span>
                    }
                    else if (isPendiente)
                    {
                        <span class="inline-flex items-center gap-xs px-3 py-1 rounded-full bg-surface-container-highest text-on-surface text-label-md font-label-md border border-outline-variant">
                            <span class="material-symbols-outlined text-[16px]">schedule</span>
                            Por vencer
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center gap-xs px-3 py-1 rounded-full bg-secondary-container text-on-secondary-container text-label-md font-label-md">
                            <span class="material-symbols-outlined text-[16px]">check_circle</span>
                            Al día
                        </span>
                    }
                </div>
            </a>
        }
        
        @if(!Model.Any())
        {
            <div class="text-center p-8 text-on-surface-variant bg-surface-container-lowest rounded-lg border border-outline-variant">
                <span class="material-symbols-outlined text-4xl opacity-50 mb-2">vaccines</span>
                <p>No hay vacunas aplicadas registradas en el sistema.</p>
            </div>
        }
    </div>
</div>
