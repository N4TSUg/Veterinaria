@model Veterinaria.ViewModels.Cliente.ClienteEditVM

@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="max-w-2xl mx-auto bg-surface-container-lowest border border-outline-variant rounded-xl p-lg shadow-sm">
    <div class="flex items-center gap-2 mb-6 border-b border-outline-variant pb-4">
        <span class="material-symbols-outlined text-primary text-3xl">edit</span>
        <h2 class="text-headline-md font-headline-md text-on-surface">Editar Cliente</h2>
    </div>

    <form asp-action="Edit" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdCliente" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label asp-for="Nombre" class="block text-label-md font-label-md text-on-surface mb-2">Nombre</label>
                <input asp-for="Nombre" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" />
                <span asp-validation-for="Nombre" class="text-error text-xs mt-1 block"></span>
            </div>
            
            <div>
                <label asp-for="Apellido" class="block text-label-md font-label-md text-on-surface mb-2">Apellido</label>
                <input asp-for="Apellido" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" />
                <span asp-validation-for="Apellido" class="text-error text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="DNI" class="block text-label-md font-label-md text-on-surface mb-2">DNI</label>
                <input asp-for="DNI" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" />
                <span asp-validation-for="DNI" class="text-error text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Telefono" class="block text-label-md font-label-md text-on-surface mb-2">Teléfono</label>
                <input asp-for="Telefono" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" />
                <span asp-validation-for="Telefono" class="text-error text-xs mt-1 block"></span>
            </div>
        </div>

        <div>
            <label asp-for="Direccion" class="block text-label-md font-label-md text-on-surface mb-2">Dirección</label>
            <input asp-for="Direccion" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" />
            <span asp-validation-for="Direccion" class="text-error text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="Correo" class="block text-label-md font-label-md text-on-surface mb-2">Correo (Opcional)</label>
            <input asp-for="Correo" type="email" class="w-full px-4 py-2 bg-surface-bright border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" />
            <span asp-validation-for="Correo" class="text-error text-xs mt-1 block"></span>
        </div>

        <div class="flex justify-end gap-4 pt-4 border-t border-outline-variant">
            <a asp-action="Index" class="px-6 py-2 border border-outline-variant text-on-surface-variant rounded-lg hover:bg-surface-container transition-colors">Cancelar</a>
            <button type="submit" class="bg-primary text-on-primary px-6 py-2 rounded-lg hover:bg-on-primary-fixed-variant transition-colors shadow">Actualizar Cliente</button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
