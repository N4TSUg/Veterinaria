@model Veterinaria.Models.Cliente

@{
    ViewData["Title"] = "Perfil de Cliente - " + Model.Nombre;
}

<div class="flex flex-col gap-lg">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-md mb-sm">
        <div>
            <div class="flex items-center gap-xs text-on-surface-variant text-label-md font-label-md mb-unit">
                <a asp-action="Index" class="hover:text-primary transition-colors">Clientes</a>
                <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                <span class="text-on-surface">Perfil Detallado</span>
            </div>
            <h2 class="text-headline-lg font-headline-lg text-on-surface">Perfil de Cliente</h2>
        </div>
        <div class="flex items-center gap-sm">
            <a asp-action="Edit" asp-route-id="@Model.IdCliente" class="bg-surface-container-lowest border border-outline-variant text-primary hover:bg-surface-container-low py-sm px-md rounded-lg text-label-md font-label-md transition-colors flex items-center gap-xs shadow-sm cursor-pointer">
                <span class="material-symbols-outlined text-[18px]">edit</span>
                Editar Cliente
            </a>
            <a asp-controller="Mascota" asp-action="Create" asp-route-idCliente="@Model.IdCliente" class="bg-primary text-on-primary hover:bg-primary-container py-sm px-md rounded-lg text-label-md font-label-md transition-colors shadow-sm flex items-center gap-xs cursor-pointer">
                <span class="material-symbols-outlined text-[18px]">pets</span>
                Agregar Mascota
            </a>
        </div>
    </div>

    <!-- Layout: Left Info, Right Mascotas -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
        
        <!-- Left: Cliente Info -->
        <div class="lg:col-span-1 flex flex-col gap-md">
            <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-lg shadow-sm">
                <div class="flex items-center gap-md mb-md border-b border-outline-variant pb-md">
                    <div class="w-16 h-16 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center text-headline-sm font-bold">
                        @Model.Nombre.Substring(0,1)@Model.Apellido.Substring(0,1)
                    </div>
                    <div>
                        <h3 class="text-headline-sm font-headline-sm text-on-surface">@Model.Nombre @Model.Apellido</h3>
                        <p class="text-label-md text-on-surface-variant">DNI: @(Model.DNI ?? "No registrado")</p>
                    </div>
                </div>

                <div class="space-y-4 text-body-md">
                    <div>
                        <span class="block text-label-md text-on-surface-variant uppercase mb-1">Teléfono</span>
                        <div class="flex items-center gap-2 text-on-surface font-medium">
                            <span class="material-symbols-outlined text-sm text-primary">call</span>
                            @(Model.Telefono ?? "No registrado")
                        </div>
                    </div>
                    
                    <div>
                        <span class="block text-label-md text-on-surface-variant uppercase mb-1">Correo Electrónico</span>
                        <div class="flex items-center gap-2 text-on-surface">
                            <span class="material-symbols-outlined text-sm text-primary">mail</span>
                            @(Model.Correo ?? "No registrado")
                        </div>
                    </div>

                    <div>
                        <span class="block text-label-md text-on-surface-variant uppercase mb-1">Dirección</span>
                        <div class="flex items-center gap-2 text-on-surface">
                            <span class="material-symbols-outlined text-sm text-primary">location_on</span>
                            @(Model.Direccion ?? "No registrada")
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Mascotas List -->
        <div class="lg:col-span-2">
            <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
                <div class="p-4 border-b border-outline-variant bg-surface-container-low flex justify-between items-center">
                    <h3 class="text-headline-sm font-headline-sm text-on-surface flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">pets</span>
                        Mascotas Registradas
                    </h3>
                    <span class="bg-primary-container text-on-primary-container px-3 py-1 rounded-full text-label-sm font-bold">
                        @(Model.Mascotas?.Count ?? 0)
                    </span>
                </div>
                
                <div class="divide-y divide-outline-variant">
                    @if (Model.Mascotas != null && Model.Mascotas.Any())
                    {
                        foreach (var mascota in Model.Mascotas)
                        {
                            <a asp-controller="Mascota" asp-action="Details" asp-route-id="@mascota.IdMascota" class="flex items-center justify-between p-4 hover:bg-surface-container-lowest transition-colors group block">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 rounded-full bg-surface-variant flex items-center justify-center text-on-surface-variant">
                                        <span class="material-symbols-outlined">@(mascota.Especie.ToLower().Contains("felino") || mascota.Especie.ToLower().Contains("gato") ? "cruelty_free" : "pets")</span>
                                    </div>
                                    <div>
                                        <h4 class="text-body-lg font-bold text-on-surface group-hover:text-primary transition-colors">@mascota.Nombre</h4>
                                        <p class="text-label-md text-on-surface-variant">@mascota.Especie - @mascota.Raza • @mascota.Edad años</p>
                                    </div>
                                </div>
                                <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">chevron_right</span>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="text-center p-8 text-on-surface-variant">
                            <span class="material-symbols-outlined text-4xl opacity-50 mb-2">pets</span>
                            <p>Este cliente no tiene mascotas registradas.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
